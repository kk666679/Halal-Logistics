# HalalChain AI Assistant Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/halalchain?schema=public

# ===========================================
# AI Provider Configuration
# ===========================================

# OpenAI (Primary Provider)
OPENAI_API_KEY=sk-your-openai-api-key

# Ollama Cloud (Secondary Provider)
# Create an API key at https://ollama.com/settings/keys
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_HOST=https://ollama.com

# Default LLM Provider: 'openai' | 'ollama'
DEFAULT_LLM_PROVIDER=openai

# ===========================================
# Vector Database (Weaviate)
# ===========================================
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=your-weaviate-api-key

# ===========================================
# Authentication (Clerk)
# ===========================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret

# ===========================================
# Application Configuration
# ===========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
